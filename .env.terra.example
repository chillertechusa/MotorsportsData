# Terra OAuth 2.0 Configuration
# Get these from https://console.tryterra.co/

# Terra API Key
TERRA_API_KEY=your_terra_api_key_here

# Terra Developer ID
TERRA_DEV_ID=your_terra_dev_id_here

# Terra Webhook Secret (for verifying callbacks)
TERRA_WEBHOOK_SECRET=your_terra_webhook_secret_here

# Terra OAuth Client ID (from OAuth app settings)
TERRA_CLIENT_ID=your_terra_client_id_here

# Terra OAuth Client Secret (from OAuth app settings)
TERRA_CLIENT_SECRET=your_terra_client_secret_here

# Motorsports Data OAuth URLs (provide these to Terra)
TERRA_AUTHORIZE_URL=https://motorsportsdata.io/auth/terra/authorize
TERRA_TOKEN_URL=https://motorsportsdata.io/auth/terra/token
TERRA_REVOKE_URL=https://motorsportsdata.io/auth/terra/revoke
TERRA_REFRESH_URL=https://motorsportsdata.io/auth/terra/refresh

# Terra Environment (dev or prod)
TERRA_ENVIRONMENT=prod
